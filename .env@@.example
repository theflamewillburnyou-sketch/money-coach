# =========================================
# MIDNIGHT MONEY COACH - Environment Setup
# =========================================
# Copy this file to ".env" and fill in your real values.
# NEVER commit your real .env to git.

# Server configuration
PORT=3000
NODE_ENV=development

# Razorpay API Keys
# Get these from: https://dashboard.razorpay.com/app/keys
# Use TEST keys (starting with rzp_test_) during development
# Switch to LIVE keys (starting with rzp_live_) only after KYC approval
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Price for premium unlock (in paise; 9900 = ₹99)
UNLOCK_PRICE_PAISE=9900

# Frontend origin (for CORS in production set to your domain)
# e.g. https://midnightmoney.in
CLIENT_ORIGIN=*
